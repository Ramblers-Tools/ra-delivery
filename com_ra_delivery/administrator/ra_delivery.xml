<?xml version="1.0" encoding="utf-8"?>
<extension type="component" version="4.0" method="upgrade">
    <name>com_ra_delivery</name>
    <creationDate>23 Jun 2026</creationDate>
    <copyright>2026 Ramblers Tools</copyright>
    <license>GNU General Public License version 3 or later; see LICENSE.txt</license>
    <author>Ramblers Tools</author>
    <authorEmail>support@ramblers.tools</authorEmail>
    <authorUrl>https://ramblers.tools</authorUrl>
    <version>1.0.5</version>
    <description>RA Delivery</description>
    <changelogurl>https://raw.githubusercontent.com/Ramblers-Tools/ra-delivery/main/changelog.xml</changelogurl>
    <namespace path="src">Ramblers\Component\Ra_delivery</namespace>
    <scriptfile>script.php</scriptfile>
    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>
    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/</schemapath>
        </schemas>
    </update>
    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>
    <files folder="site">
        <folder>src</folder>
    </files>
    <administration>
        <menu link="option=com_ra_delivery&amp;view=deliveryevents">RA Delivery</menu>
        <files folder="administrator">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <folder>forms</folder>
            <folder>languages</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>
        <languages folder="administrator/languages">
			<language tag="en-GB">en-GB/com_ra_delivery.ini</language>
			<language tag="en-GB">en-GB/com_ra_delivery.sys.ini</language>
        </languages>
    </administration>
</extension>
